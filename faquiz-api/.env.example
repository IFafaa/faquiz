# PostgreSQL (ex.: Docker: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=faquiz -e POSTGRES_USER=faquiz -e POSTGRES_DB=faquiz postgres:16-alpine)
DATABASE_URL="postgresql://faquiz:faquiz@localhost:5432/faquiz?schema=public"
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="7d"
PORT=3333
FRONTEND_URL="http://localhost:5173"
# Em NODE_ENV=production o seed exige esta variável na primeira carga (senha do usuário demo inicial).
# ADMIN_SEED_PASSWORD=""
# Opcional: credenciais preferidas em scripts/E2E (ADMIN_* ainda funciona como fallback).
# FAQUIZ_USER_EMAIL=""
# FAQUIZ_USER_PASSWORD=""
